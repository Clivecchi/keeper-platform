{
  "extends": "./base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020", "ES6", "ESNext"],
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["vite/client", "node"],
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "skipLibCheck": true
  }
} 