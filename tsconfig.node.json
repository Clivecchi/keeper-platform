{
  "compilerOptions": {
    "outDir": "dist",
    "module": "NodeNext",
    "target": "es2020",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/index.ts", "src/kam/**/*"],
  "exclude": ["src/components", "src/context", "src/hooks", "src/pages", "src/lib"]
}
