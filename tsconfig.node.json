{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "outDir": "dist"
  },
  "include": [
    "src/api/**/*.ts",
    "src/kam/**/*.ts",
    "src/index.ts"
  ],
  "exclude": ["src/**/*.tsx"]
}
