{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter keeper-web build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "routes": [
    {
      "handle": "proxy",
      "src": "/api/(.*)",
      "dest": "https://keeper-platform-production.up.railway.app/api/$1"
    },
    { "handle": "filesystem" },
    {
      "src": "(.*)",
      "dest": "/apps/web/dist/$1"
    }
  ]
} 