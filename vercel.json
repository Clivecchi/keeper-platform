{
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://keeper-platform-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "https://keeper-platform-production.up.railway.app/$1"
    }
  ]
}