{
  "installCommand": "pnpm install --frozen-lockfile --prod=false",
  "buildCommand": "cd apps/web && pnpm build",
  "outputDirectory": "apps/web/dist",

  "routes": [
    { "handle": "filesystem" },

    { "src": "/api/(.*)", "dest": "https://keeper-platform-production.up.railway.app/api/$1" },

    { "src": "/mcp$", "dest": "https://keeper-platform-production.up.railway.app/mcp" },
    { "src": "/mcp/(.*)", "dest": "https://keeper-platform-production.up.railway.app/mcp/$1" },

    { "src": "/(.*)", "dest": "/index.html" }
  ],

  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ke3p.com" }],
      "destination": "https://www.ke3p.com/$1",
      "permanent": true
    }
  ]
}
