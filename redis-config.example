# DEPRECATED: Use .env.example instead.
# Redis Configuration Example
# Copy this file to .env and configure your Redis settings

# Redis Configuration
# Set REDIS_URL to connect to a Redis instance
# Set DISABLE_REDIS=true to disable Redis functionality (uses no-op adapter)
REDIS_URL=redis://localhost:6379
DISABLE_REDIS=false

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/keeper_platform"

# Authentication
JWT_SECRET=your-jwt-secret-here
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# API Configuration
API_PORT=3001
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
