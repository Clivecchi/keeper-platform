{
  "name": "@keeper/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "build": "prisma generate && tsc --build --force",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "push": "prisma db push",
    "pull": "prisma db pull",
    "studio": "prisma studio",
    "migrate": "prisma migrate dev",
    "reset": "prisma migrate reset"
  },
  "dependencies": {
    "@keeper/shared": "workspace:*",
    "@prisma/client": "^6.11.1",
    "ioredis": "^5.6.1",
    "node-cron": "^4.2.1",
    "prisma": "^6.11.1",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "typescript": "~5.8.3"
  }
}