{
  "name": "@keeper/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./queries": {
      "import": "./src/queries/index.ts",
      "types": "./src/queries/index.ts"
    },
    "./types": {
      "import": "./src/types.ts",
      "types": "./src/types.ts"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "type-check": "tsc --noEmit",
    "generate": "prisma generate",
    "push": "prisma db push",
    "pull": "prisma db pull",
    "studio": "prisma studio",
    "migrate": "prisma migrate dev",
    "reset": "prisma migrate reset"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0"
  },
  "devDependencies": {
    "prisma": "^6.9.0",
    "typescript": "~5.8.3"
  }
} 