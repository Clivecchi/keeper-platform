/// Third-party service connection — Services use Nango OAuth; Custom uses platform env tokens.
enum IntegrationType {
  Services
  Custom
  AI_Model
}

/// Third-party service connection — credentials live in Nango (Services) or env (Custom).
model Integration {
  id                String           @id @default(cuid())
  service           String
  integration_type  IntegrationType
  nangoConnectionId String?
  status            String           @default("disconnected")
  tier              String           @default("platform")
  scopes            String[]
  domainId          String?
  userId            String?
  metadata          Json?
  connectedAt       DateTime?
  chronicle_blocks  String[]         @default([])
  chronicle_actions String[]         @default([])
  is_gateway        Boolean          @default(false)
  display_label     String?
  description       String?
  connect_copy      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  providerKeys      Key[]

  @@unique([service, tier, domainId, userId])
}

/// Provider API key — EntityKind presence layer over kip_user_keys / kip_platform_keys / env.
model Key {
  id                String    @id @default(cuid())
  provider          String
  key_source        String
  status            String    @default("unknown")
  scope             String?
  last_verified     DateTime?
  expires_at        DateTime?
  domain_id         String
  user_id           String?
  integration_id    String?
  chronicle_blocks  String[]  @default([])
  chronicle_actions String[]  @default([])
  display_label     String?
  description       String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  domain      Domain       @relation(fields: [domain_id], references: [id], onDelete: Cascade)
  user        users?       @relation(fields: [user_id], references: [id], onDelete: SetNull)
  integration Integration? @relation(fields: [integration_id], references: [id], onDelete: SetNull)

  @@unique([domain_id, provider, key_source, user_id])
  @@index([domain_id])
  @@index([provider])
  @@index([integration_id])
  @@index([user_id])
}