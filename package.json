{
  "name": "keeper-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"pnpm --filter ./apps/api dev\" \"pnpm --filter ./apps/web dev\"",
    "dev:api": "pnpm --filter ./apps/api dev",
    "dev:web": "pnpm --filter ./apps/web dev",
    "prepare": "pnpm prisma generate",
    "build": "pnpm -r --filter ./apps build",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "tailwind:init": "tailwindcss init -p",
    "db:pull": "dotenv -e .env -- pnpm prisma db pull",
    "db:push": "dotenv -e .env -- pnpm prisma db push",
    "db:generate": "dotenv -e .env -- pnpm prisma generate",
    "db:studio": "dotenv -e .env -- pnpm prisma studio",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@tailwindcss/vite": "^4.1.8",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "framer-motion": "^12.16.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.513.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.45"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.4",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "concurrently": "^8.2.2"
  }
}
