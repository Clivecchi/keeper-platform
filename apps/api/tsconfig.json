{
  "extends": "../../tools/tsconfig/node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "src/index.ts",
    "src/middleware/logRequestMiddleware.ts",
    "src/middleware/authMiddleware.ts",
    "src/middleware/validationMiddleware.ts",
    "src/api/kam/settings.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/middleware/domainPermissionMiddleware.ts", 
    "src/middleware/domainResolutionMiddleware.ts",
    "src/middleware/dynamicCorsMiddleware.ts",
    "src/middleware/memoryAccessMiddleware.ts",
    "src/api/domains/routes.ts",
    "src/api/domains/custom-domain-routes.ts",
    "src/__tests__"
  ]
} 