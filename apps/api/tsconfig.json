{
  "extends": "../../tools/tsconfig/node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "src/index.ts",
    "src/middleware/logRequestMiddleware.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/api",
    "src/middleware/authMiddleware.ts",
    "src/middleware/domainPermissionMiddleware.ts", 
    "src/middleware/domainResolutionMiddleware.ts",
    "src/middleware/dynamicCorsMiddleware.ts",
    "src/middleware/memoryAccessMiddleware.ts",
    "src/middleware/validationMiddleware.ts",
    "src/__tests__"
  ]
} 