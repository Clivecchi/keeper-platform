{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm --filter proxy build"
  },
  "deploy": {
    "startCommand": "sh -c 'cd apps/proxy && node dist/index.js'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

