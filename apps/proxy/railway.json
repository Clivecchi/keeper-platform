{
  "$schema": "https://railway.app/railway.schema.json",
  "rootDirectory": ".",
  "build": {
    "builder": "dockerfile",
    "dockerfilePath": "Dockerfile.proxy",
    "context": "."
  },
  "deploy": {
    "startCommand": "node dist/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

