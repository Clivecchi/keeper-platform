registry=https://registry.npmjs.org/

# Fallback registry for reliability
fallback-registry=https://registry.yarnpkg.com/

# Increase retry attempts for network issues
fetch-retries=5
fetch-retry-maxtimeout=60000

# Use strict SSL to ensure secure connections
strict-ssl=true

# Cache settings to avoid repeated failures
cache-min=999999
cache-max=1000000
