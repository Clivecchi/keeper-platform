{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://keeper-platform-production.up.railway.app/api/$1",
      "has": [{ "type": "host", "value": "www.ke3p.com" }]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ke3p.com" }],
      "destination": "https://www.ke3p.com/$1",
      "permanent": true
    }
  ]
}